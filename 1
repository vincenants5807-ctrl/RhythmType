<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RhythmType - 音乐节拍打字练习器</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Segoe UI',sans-serif;background:#0a0a1a;color:#e2e8f0;height:100vh;overflow:hidden;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.app{width:100%;max-width:860px;padding:20px;}
.header{display:flex;justify-content:space-between;align-items:center;margin-bottom:30px;}
.header h1{font-size:22px;color:#a78bfa;}
.stats-bar{display:flex;gap:18px;}
.stat{text-align:center;}
.stat .sv{font-size:22px;font-weight:bold;color:#a78bfa;font-family:'Fira Code',monospace;}
.stat .sl{font-size:9px;opacity:.4;margin-top:2px;}

.bpm-control{display:flex;align-items:center;gap:12px;margin-bottom:20px;padding:12px 16px;background:rgba(255,255,255,.03);border-radius:10px;}
.bpm-control label{font-size:12px;opacity:.6;}
.bpm-control input[type=range]{flex:1;accent-color:#a78bfa;}
.bpm-control .bpm-val{font-size:14px;color:#a78bfa;font-weight:bold;min-width:60px;text-align:center;}
.mode-btns{display:flex;gap:6px;margin-bottom:20px;}
.mode-btn{padding:8px 16px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;cursor:pointer;font-size:12px;transition:.2s;}
.mode-btn:hover,.mode-btn.active{background:rgba(167,139,250,.12);border-color:#a78bfa;color:#a78bfa;}

.typing-area{position:relative;padding:30px;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.06);border-radius:16px;margin-bottom:20px;min-height:160px;}
.text-display{font-size:20px;line-height:2;font-family:'Fira Code',monospace;letter-spacing:1px;word-wrap:break-word;}
.text-display .ch{transition:color .1s;}
.text-display .ch.correct{color:#22c55e;}
.text-display .ch.wrong{color:#ef4444;text-decoration:underline;}
.text-display .ch.current{background:rgba(167,139,250,.3);border-radius:3px;padding:0 1px;}
.text-display .ch.pending{opacity:.3;}

.beat-bar{height:6px;background:rgba(255,255,255,.06);border-radius:3px;margin-bottom:20px;overflow:hidden;position:relative;}
.beat-fill{height:100%;background:linear-gradient(90deg,#a78bfa,#7c3aed);border-radius:3px;transition:width .05s linear;}
.beat-flash{position:absolute;inset:0;background:rgba(167,139,250,.3);opacity:0;transition:opacity .1s;}
.beat-flash.on{opacity:1;}

.keyboard-vis{display:flex;flex-direction:column;gap:4px;align-items:center;}
.kb-row{display:flex;gap:3px;}
.kb-key{width:36px;height:36px;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:6px;font-size:11px;font-family:'Fira Code',monospace;transition:.1s;}
.kb-key.active{background:rgba(167,139,250,.3);border-color:#a78bfa;color:#a78bfa;transform:scale(.92);}
.kb-key.correct{background:rgba(34,197,94,.2);border-color:#22c55e;}
.kb-key.wrong{background:rgba(239,68,68,.2);border-color:#ef4444;}
.kb-key.space{width:200px;}

.results-panel{display:none;text-align:center;padding:30px;background:rgba(255,255,255,.03);border-radius:16px;}
.results-panel.show{display:block;}
.results-panel h2{color:#a78bfa;font-size:24px;margin-bottom:15px;}
.result-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin:15px 0;}
.rg-item{padding:12px;background:rgba(255,255,255,.03);border-radius:10px;}
.rg-item .rv{font-size:22px;font-weight:bold;color:#a78bfa;}
.rg-item .rl{font-size:10px;opacity:.4;margin-top:4px;}
.restart-btn{margin-top:15px;padding:12px 30px;background:rgba(167,139,250,.2);border:1px solid #a78bfa;border-radius:10px;color:#a78bfa;cursor:pointer;font-size:14px;font-weight:600;transition:.2s;}
.restart-btn:hover{background:rgba(167,139,250,.3);}

.history-chart{margin-top:15px;}
canvas#histChart{width:100%;height:80px;}
</style>
</head>
<body>
<div class="app">
  <div class="header">
    <h1>🎵 RhythmType</h1>
    <div class="stats-bar">
      <div class="stat"><div class="sv" id="liveWpm">0</div><div class="sl">WPM</div></div>
      <div class="stat"><div class="sv" id="liveAcc">100%</div><div class="sl">准确率</div></div>
      <div class="stat"><div class="sv" id="liveCombo">0</div><div class="sl">连击</div></div>
      <div class="stat"><div class="sv" id="liveTime">0s</div><div class="sl">用时</div></div>
    </div>
  </div>

  <div class="bpm-control">
    <label>🎶 节拍 BPM:</label>
    <input type="range" min="40" max="200" value="80" id="bpmSlider" oninput="setBPM(this.value)">
    <span class="bpm-val" id="bpmVal">80</span>
    <button class="mode-btn" onclick="toggleMetronome()" id="metBtn">🔇 节拍器</button>
  </div>

  <div class="mode-btns">
    <div class="mode-btn active" onclick="setMode('english')">English</div>
    <div class="mode-btn" onclick="setMode('code')">Code</div>
    <div class="mode-btn" onclick="setMode('chinese')">中文拼音</div>
    <div class="mode-btn" onclick="setMode('numbers')">数字</div>
    <div class="mode-btn" onclick="setMode('custom')">自定义</div>
  </div>

  <div class="beat-bar"><div class="beat-fill" id="beatFill"></div><div class="beat-flash" id="beatFlash"></div></div>

  <div class="typing-area" id="typingArea">
    <div class="text-display" id="textDisplay"></div>
  </div>

  <div class="keyboard-vis" id="keyboardVis"></div>

  <div class="results-panel" id="resultsPanel">
    <h2>🎉 练习完成!</h2>
    <div class="result-grid">
      <div class="rg-item"><div class="rv" id="resWpm">0</div><div class="rl">WPM</div></div>
      <div class="rg-item"><div class="rv" id="resAcc">0%</div><div class="rl">准确率</div></div>
      <div class="rg-item"><div class="rv" id="resTime">0s</div><div class="rl">用时</div></div>
      <div class="rg-item"><div class="rv" id="resCombo">0</div><div class="rl">最高连击</div></div>
    </div>
    <canvas id="histChart" height="80"></canvas>
    <button class="restart-btn" onclick="restart()">🔄 再来一次</button>
  </div>
</div>

<script>
const TEXTS = {
    english: [
        "The quick brown fox jumps over the lazy dog near the river bank",
        "Practice makes perfect and patience is the key to mastery",
        "Technology shapes how we learn communicate and create in modern life",
        "Every expert was once a beginner who never gave up trying",
        "Knowledge is power but wisdom is knowing how to use it well"
    ],
    code: [
        "function add(a, b) { return a + b; }",
        "const arr = [1, 2, 3].map(x => x * 2);",
        "if (user.isActive && user.age >= 18) { grant(); }",
        "async function fetch(url) { return await get(url); }",
        "class Node { constructor(val) { this.val = val; } }"
    ],
    chinese: [
        "zhong guo shi jie da xue sheng huo xue xi",
        "jin tian tian qi hen hao wo men qu gong yuan",
        "ke xue ji shu shi di yi sheng chan li",
        "du shu po wan juan xia bi ru you shen"
    ],
    numbers: [
        "3141 5926 5358 9793 2384 6264 3383 2795",
        "2718 2818 2845 9045 2353 6028 7471 3527",
        "1618 0339 8874 9894 8482 0458 6834 3656"
    ]
};

const KB_ROWS = [
    ['`','1','2','3','4','5','6','7','8','9','0','-','='],
    ['q','w','e','r','t','y','u','i','o','p','[',']','\\'],
    ['a','s','d','f','g','h','j','k','l',';','\''],
    ['z','x','c','v','b','n','m',',','.','/'],
    [' ']
];

let currentText = '';
let charIndex = 0;
let errors = 0;
let totalTyped = 0;
let startTime = 0;
let isRunning = false;
let combo = 0;
let maxCombo = 0;
let mode = 'english';
let bpm = 80;
let metronomeOn = false;
let metInterval = null;
let beatPhase = 0;
let wpmHistory = [];

// AudioContext for metronome
let audioCtx = null;

function initAudio(){
    if(!audioCtx) audioCtx = new (window.AudioContext||window.webkitAudioContext)();
}

function playTick(freq=800, dur=0.05){
    if(!audioCtx) return;
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.connect(gain); gain.connect(audioCtx.destination);
    osc.frequency.value = freq;
    gain.gain.setValueAtTime(0.3, audioCtx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime+dur);
    osc.start(); osc.stop(audioCtx.currentTime+dur);
}

function playCorrect(){ if(audioCtx){ playTick(1200, 0.03); } }
function playWrong(){ if(audioCtx){ playTick(200, 0.1); } }

function setBPM(v){
    bpm = parseInt(v);
    document.getElementById('bpmVal').textContent = bpm;
    if(metronomeOn) startMetronome();
}

function toggleMetronome(){
    initAudio();
    metronomeOn = !metronomeOn;
    document.getElementById('metBtn').textContent = metronomeOn ? '🔊 节拍器' : '🔇 节拍器';
    if(metronomeOn) startMetronome(); else stopMetronome();
}

function startMetronome(){
    stopMetronome();
    const interval = 60000 / bpm;
    metInterval = setInterval(()=>{
        playTick(1000, 0.04);
        document.getElementById('beatFlash').classList.add('on');
        setTimeout(()=>document.getElementById('beatFlash').classList.remove('on'), 100);
        beatPhase = 0;
    }, interval);
    // beat fill animation
    animateBeat(interval);
}

function stopMetronome(){ clearInterval(metInterval); metInterval=null; }

function animateBeat(interval){
    const fill = document.getElementById('beatFill');
    let start = performance.now();
    function frame(now){
        if(!metronomeOn) { fill.style.width='0%'; return; }
        const elapsed = (now - start) % interval;
        fill.style.width = (elapsed/interval*100)+'%';
        requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
}

function setMode(m){
    mode = m;
    document.querySelectorAll('.mode-btn').forEach((b,i)=>{
        b.classList.toggle('active', ['english','code','chinese','numbers','custom'][i]===m);
    });
    if(m==='custom'){
        const t = prompt('请输入自定义练习文本:');
        if(t) { TEXTS.custom = [t]; restart(); }
    } else { restart(); }
}

function restart(){
    document.getElementById('resultsPanel').classList.remove('show');
    document.getElementById('typingArea').style.display = 'block';
    const pool = TEXTS[mode] || TEXTS.english;
    currentText = pool[Math.floor(Math.random()*pool.length)];
    charIndex = 0; errors = 0; totalTyped = 0; startTime = 0; isRunning = false;
    combo = 0; maxCombo = 0; wpmHistory = [];
    renderText();
    updateLiveStats();
}

function renderText(){
    let html = '';
    for(let i=0;i<currentText.length;i++){
        let cls = 'pending';
        if(i<charIndex) cls = 'correct'; // will be overridden if wrong
        if(i===charIndex) cls = 'current';
        html += `<span class="ch ${cls}" id="ch${i}">${currentText[i]===' '?'&nbsp;':escHtml(currentText[i])}</span>`;
    }
    document.getElementById('textDisplay').innerHTML = html;
}

function escHtml(c){ return c.replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function renderKeyboard(){
    let html = '';
    KB_ROWS.forEach(row=>{
        html += '<div class="kb-row">';
        row.forEach(k=>{
            const cls = k===' '?'kb-key space':'kb-key';
            html += `<div class="${cls}" id="key_${k.charCodeAt(0)}">${k===' '?'Space':k}</div>`;
        });
        html += '</div>';
    });
    document.getElementById('keyboardVis').innerHTML = html;
}

// ====== 输入处理 ======
document.addEventListener('keydown', e=>{
    if(e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA') return;
    if(document.getElementById('resultsPanel').classList.contains('show')) return;
    if(e.key==='Escape'){ restart(); return; }
    if(e.key.length>1 && e.key!=='Backspace') return;
    e.preventDefault();
    initAudio();

    if(e.key==='Backspace'){
        if(charIndex>0){ charIndex--; totalTyped--; renderText(); }
        return;
    }

    if(!isRunning){ isRunning=true; startTime=Date.now(); startTimer(); }

    const expected = currentText[charIndex];
    const typed = e.key;
    totalTyped++;

    // 高亮键盘
    highlightKey(typed, typed===expected);

    if(typed===expected){
        playCorrect();
        document.getElementById('ch'+charIndex).className = 'ch correct';
        combo++; if(combo>maxCombo) maxCombo=combo;
        charIndex++;
    } else {
        playWrong();
        document.getElementById('ch'+charIndex).className = 'ch wrong';
        errors++;
        combo = 0;
        charIndex++;
    }

    updateLiveStats();

    if(charIndex >= currentText.length){
        finishTest();
    } else {
        renderText(); // re-render to update current highlight
        // fix: manually set classes for typed chars
        for(let i=0;i<charIndex;i++){
            // we already handled above
        }
    }
});

function highlightKey(ch, correct){
    const code = ch.toLowerCase().charCodeAt(0);
    const el = document.getElementById('key_'+code);
    if(!el) return;
    el.classList.add('active');
    el.classList.add(correct?'correct':'wrong');
    setTimeout(()=>{ el.classList.remove('active','correct','wrong'); }, 200);
}

function startTimer(){
    const iv = setInterval(()=>{
        if(!isRunning){ clearInterval(iv); return; }
        const elapsed = (Date.now()-startTime)/1000;
        document.getElementById('liveTime').textContent = elapsed.toFixed(0)+'s';
        // WPM history
        if(elapsed>0){
            const wpm = Math.round((charIndex/5)/(elapsed/60));
            wpmHistory.push(wpm);
        }
    }, 500);
}

function updateLiveStats(){
    const elapsed = startTime ? (Date.now()-startTime)/1000 : 0;
    const wpm = elapsed>0 ? Math.round((charIndex/5)/(elapsed/60)) : 0;
    const acc = totalTyped>0 ? Math.round((totalTyped-errors)/totalTyped*100) : 100;
    document.getElementById('liveWpm').textContent = wpm;
    document.getElementById('liveAcc').textContent = acc+'%';
    document.getElementById('liveCombo').textContent = combo;
}

function finishTest(){
    isRunning = false;
    const elapsed = (Date.now()-startTime)/1000;
    const wpm = Math.round((currentText.length/5)/(elapsed/60));
    const acc = Math.round((totalTyped-errors)/totalTyped*100);

    document.getElementById('typingArea').style.display = 'none';
    document.getElementById('resultsPanel').classList.add('show');
    document.getElementById('resWpm').textContent = wpm;
    document.getElementById('resAcc').textContent = acc+'%';
    document.getElementById('resTime').textContent = elapsed.toFixed(1)+'s';
    document.getElementById('resCombo').textContent = maxCombo;

    // 保存历史
    const hist = JSON.parse(localStorage.getItem('rhythmtype_hist')||'[]');
    hist.push({wpm, acc, time:elapsed, date:new Date().toISOString(), mode});
    if(hist.length>100) hist.shift();
    localStorage.setItem('rhythmtype_hist', JSON.stringify(hist));

    drawHistChart();
}

function drawHistChart(){
    const canvas = document.getElementById('histChart');
    const c = canvas.getContext('2d');
    canvas.width = canvas.offsetWidth*2; canvas.height = 160;
    c.scale(2,2);
    const w=canvas.offsetWidth, h=80;
    if(wpmHistory.length<2) return;
    const max = Math.max(...wpmHistory,1);
    c.strokeStyle='#a78bfa'; c.lineWidth=2; c.beginPath();
    wpmHistory.forEach((v,i)=>{
        const x = (i/(wpmHistory.length-1))*w;
        const y = h - (v/max)*(h-10);
        i===0?c.moveTo(x,y):c.lineTo(x,y);
    });
    c.stroke();
    c.fillStyle='rgba(167,139,250,.1)';
    c.lineTo(w,h); c.lineTo(0,h); c.closePath(); c.fill();
    c.fillStyle='rgba(255,255,255,.3)'; c.font='9px sans-serif';
    c.fillText('WPM 变化趋势', 5, 12);
}

// ====== 初始化 ======
renderKeyboard();
restart();
</script>
</body>
</html>
